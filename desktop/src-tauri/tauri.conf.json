{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "达人榜单",
  "version": "0.1.0",
  "identifier": "com.lyle.douyincreatordesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "达人榜单",
        "width": 1360,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/douyin-backend"]
  }
}
